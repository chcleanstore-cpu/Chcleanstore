<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, viewport-fit=cover">
  <title>CH Clean Store | متجر المنظفات</title>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
    body {
      font-family: 'Cairo', 'Segoe UI', system-ui, sans-serif;
      background: #f0f2f5;
      color: #1e293b;
      direction: rtl;
      text-align: right;
      min-height: 100vh;
      padding-bottom: 80px;
    }
    :root {
      --primary: #10b981;
      --primary-dark: #059669;
      --success: #2ecc71;
      --danger: #e74c3c;
      --warning: #f39c12;
      --vip: #8e44ad;
      --vip-light: #f3e9ff;
      --card: #ffffff;
      --text: #1e293b;
      --muted: #64748b;
      --border: #e2e8f0;
      --shadow-sm: 0 2px 8px rgba(0,0,0,0.04);
      --shadow-md: 0 8px 20px rgba(0,0,0,0.06);
      --shadow-lg: 0 12px 28px rgba(0,0,0,0.1);
      --radius-card: 20px;
    }
    header {
      position: sticky;
      top: 0;
      z-index: 1100;
      background: rgba(255,255,255,0.96);
      backdrop-filter: blur(12px);
      box-shadow: var(--shadow-sm);
      padding: 12px 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid rgba(0,0,0,0.05);
    }
    .logo {
      font-size: 1.3rem;
      font-weight: 800;
      background: linear-gradient(135deg, #1e293b, var(--primary));
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      cursor: pointer;
    }
    .nav-icons i {
      font-size: 1.4rem;
      margin-right: 18px;
      cursor: pointer;
      color: #475569;
      transition: 0.2s;
    }
    .nav-icons i:hover { color: var(--primary); transform: scale(1.05); }
    #searchContainer {
      padding: 12px 20px;
      background: white;
      border-bottom: 1px solid var(--border);
      display: none;
    }
    #searchContainer.active { display: block; animation: fadeIn 0.2s ease; }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(-10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    #searchInput {
      width: 100%;
      padding: 14px 20px;
      border-radius: 50px;
      border: 1px solid var(--border);
      background: #f8fafc;
      font-size: 1rem;
      font-family: inherit;
      outline: none;
    }
    #searchInput:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 3px rgba(16,185,129,0.15);
    }
    .banner { width: 100%; margin: 0; padding: 0; }
    #coverImage {
      width: 100%;
      height: auto;
      max-height: 280px;
      object-fit: cover;
      display: block;
    }
    @media (min-width: 768px) { #coverImage { max-height: 400px; } }
    .categories-bar {
      display: flex;
      overflow-x: auto;
      gap: 12px;
      padding: 14px 20px;
      background: white;
      border-bottom: 1px solid var(--border);
      scrollbar-width: thin;
    }
    .categories-bar::-webkit-scrollbar { display: none; }
    .cat-btn {
      white-space: nowrap;
      padding: 8px 20px;
      border-radius: 40px;
      border: none;
      background: #f1f5f9;
      font-weight: 700;
      font-size: 0.85rem;
      color: #475569;
      cursor: pointer;
      transition: all 0.2s;
    }
    .cat-btn.active {
      background: linear-gradient(135deg, var(--primary), #34d399);
      color: white;
      box-shadow: 0 4px 12px rgba(16,185,129,0.3);
    }
    .vip-box {
      background: linear-gradient(145deg, #ffffff, #fafcff);
      margin: 16px 20px;
      padding: 18px;
      border-radius: 28px;
      box-shadow: var(--shadow-md);
      border: 1px solid rgba(0,0,0,0.03);
      display: none;
    }
    .vip-top {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 16px;
    }
    .vip-icon {
      width: 55px;
      height: 55px;
      background: linear-gradient(135deg, #f39c12, #f1c40f);
      border-radius: 18px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.6rem;
      color: white;
      box-shadow: 0 6px 14px rgba(243,156,18,0.3);
    }
    .vip-text h3 { font-size: 1rem; font-weight: 800; margin-bottom: 4px; }
    .vip-text p { font-size: 0.75rem; color: var(--muted); }
    .vip-form { display: flex; gap: 12px; }
    .vip-form input {
      flex: 1;
      padding: 14px;
      border: 1px solid var(--border);
      border-radius: 30px;
      background: #f8fafc;
      font-family: inherit;
      outline: none;
    }
    .vip-form button {
      background: linear-gradient(135deg, #27ae60, #2ecc71);
      border: none;
      padding: 0 24px;
      border-radius: 40px;
      color: white;
      font-weight: 700;
      cursor: pointer;
    }
    @media (max-width: 480px) { .vip-form { flex-direction: column; } .vip-form button { padding: 12px; } }
    .products-container {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 18px;
      padding: 16px 20px;
    }
    @media (min-width: 640px) { .products-container { grid-template-columns: repeat(3,1fr); } }
    @media (min-width: 1024px) { .products-container { grid-template-columns: repeat(4,1fr); } }
    @media (min-width: 1400px) { .products-container { grid-template-columns: repeat(5,1fr); } }
    .product-card {
      background: var(--card);
      border-radius: var(--radius-card);
      overflow: hidden;
      transition: 0.25s ease;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border);
    }
    .product-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-lg); }
    .product-card img {
      width: 100%;
      height: 180px;
      object-fit: cover;
      cursor: pointer;
      background: #f1f5f9;
    }
    .product-info { padding: 12px; }
    .product-info h3 {
      font-size: 0.9rem;
      font-weight: 700;
      margin-bottom: 6px;
      line-height: 1.4;
      height: 2.5rem;
      overflow: hidden;
    }
    .product-price {
      font-size: 1.1rem;
      font-weight: 800;
      color: var(--primary);
      margin-bottom: 8px;
    }
    .qty-controls {
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: #f8fafc;
      padding: 6px;
      border-radius: 40px;
      gap: 4px;
    }
    .qty-btn {
      width: 36px;
      height: 36px;
      border: none;
      border-radius: 30px;
      background: white;
      font-weight: bold;
      font-size: 1.2rem;
      cursor: pointer;
      box-shadow: var(--shadow-sm);
    }
    .qty-input {
      width: 55px;
      text-align: center;
      border: 1px solid var(--border);
      border-radius: 30px;
      padding: 8px 0;
      background: white;
    }
    #cartBtn {
      position: fixed;
      bottom: 24px;
      right: 24px;
      width: 60px;
      height: 60px;
      border-radius: 30px;
      background: linear-gradient(135deg, var(--primary), #34d399);
      border: none;
      color: white;
      font-size: 1.6rem;
      box-shadow: 0 8px 22px rgba(16,185,129,0.4);
      cursor: pointer;
      z-index: 1050;
      transition: 0.2s;
    }
    #cartBtn:hover { transform: scale(1.05); }
    #cartBadge {
      position: absolute;
      top: -5px;
      left: -5px;
      background: var(--danger);
      color: white;
      border-radius: 30px;
      padding: 2px 8px;
      font-size: 0.7rem;
      font-weight: bold;
    }
    .modal {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.5);
      backdrop-filter: blur(8px);
      z-index: 2000;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .modal-content {
      background: white;
      width: 100%;
      max-width: 480px;
      border-radius: 32px;
      padding: 24px;
      box-shadow: var(--shadow-lg);
      animation: fadeUp 0.2s ease;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .form-control {
      width: 100%;
      padding: 14px;
      margin-bottom: 14px;
      border: 1px solid var(--border);
      border-radius: 24px;
      font-family: inherit;
    }
    .btn-order {
      background: linear-gradient(135deg, var(--primary), #34d399);
      width: 100%;
      padding: 14px;
      border: none;
      border-radius: 40px;
      color: white;
      font-weight: 700;
      cursor: pointer;
    }
    #cartItemsList { max-height: 300px; overflow-y: auto; margin-bottom: 16px; }
    #pagination { text-align: center; margin: 20px 0; }
    #pagination button {
      min-width: 38px;
      height: 38px;
      border: none;
      border-radius: 10px;
      margin: 4px;
      background: white;
      color: #333;
      font-weight: 600;
      box-shadow: 0 2px 6px rgba(0,0,0,0.08);
      cursor: pointer;
      transition: 0.2s;
    }
    #pagination button:hover { transform: translateY(-2px); background: var(--primary); color: white; }
    #pagination .active-page { background: var(--primary); color: white; }
    body.vip-active { background: var(--vip-light); }
    body.vip-active .product-price { color: var(--vip); }
    body.vip-active #cartBtn { background: linear-gradient(135deg, var(--vip), #9b59b6); }
    body.vip-active .cat-btn.active { background: var(--vip); }
    footer {
      text-align: center;
      padding: 24px;
      background: white;
      margin-top: 30px;
      font-size: 0.8rem;
      color: var(--muted);
      border-top: 1px solid var(--border);
    }
    footer a { color: var(--primary); text-decoration: none; }
    .whatsapp-btn {
      background: linear-gradient(135deg, #25D366, #128C7E) !important;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font-size: 16px;
    }
    .whatsapp-btn i { font-size: 22px; }
    .location-btn {
      background: #4285F4;
      color: white;
      border: none;
      border-radius: 40px;
      padding: 12px 16px;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 14px;
      white-space: nowrap;
      transition: 0.2s;
    }
    .location-btn:hover { opacity: 0.9; transform: scale(0.98); }
    .location-btn i { font-size: 16px; }
    .address-container {
      display: flex;
      gap: 10px;
      align-items: center;
      margin-bottom: 14px;
    }
    .address-container input {
      flex: 3;
      margin-bottom: 0;
    }
    @media (max-width: 550px) {
      .address-container { flex-direction: column; }
      .address-container input { width: 100%; margin-bottom: 10px; }
      .location-btn { width: 100%; justify-content: center; }
    }
  </style>
</head>
<body>

<header>
  <div class="logo" onclick="toggleVIPBox()">
    <i class="fa-solid fa-broom" style="margin-left: 6px;"></i> CH Clean Store
  </div>
  <div class="nav-icons">
    <i class="fa-solid fa-magnifying-glass" onclick="toggleSearch()"></i>
  </div>
</header>

<div id="searchContainer">
  <input type="text" id="searchInput" placeholder="ابحث باسم المنتج أو الرمز...">
</div>

<div class="banner">
  <img id="coverImage" src="" alt="غلاف المتجر">
</div>

<div class="categories-bar" id="categoriesBar"></div>

<div id="vipBox" class="vip-box">
  <div class="vip-top">
    <div class="vip-icon"><i class="fa-solid fa-crown"></i></div>
    <div class="vip-text">
      <h3 id="vipStatus">💎 أسعار الجملة</h3>
      <p>أدخل الكود لتفعيل الخصم الخاص</p>
    </div>
  </div>
  <div class="vip-form">
    <input type="text" id="vipInput" placeholder="رمز التفعيل">
    <button onclick="checkVIP()">تفعيل</button>
  </div>
</div>

<div class="products-container" id="productsContainer"></div>
<div id="pagination"></div>

<button id="cartBtn" onclick="openCart()">
  <i class="fa-solid fa-cart-shopping"></i>
  <span id="cartBadge" style="display: none;">0</span>
</button>

<!-- Cart Modal -->
<div id="cartModal" class="modal">
  <div class="modal-content">
    <h3 style="text-align:center;">🛒 سلة التسوق</h3>
    <div id="cartItemsList"></div>
    <div id="cartTotal" style="font-weight:800; text-align:center; margin:10px 0;"></div>
    <input type="text" id="custName" class="form-control" placeholder="الاسم الكامل">
    <input type="tel" id="custPhone" class="form-control" placeholder="رقم الهاتف">
    
    <div class="address-container">
      <input type="text" id="custAddress" class="form-control" placeholder="العنوان (المدينة، المنطقة، ...)">
      <button type="button" id="locationBtn" class="location-btn">
        <i class="fab fa-google"></i> <i class="fas fa-map-marker-alt"></i> تحديد الموقع
      </button>
    </div>
    
    <button class="btn-order whatsapp-btn" id="sendBtn" onclick="submitOrder()">
      <i class="fab fa-whatsapp" style="margin-left: 8px; font-size: 20px;"></i>
      إرسال الطلب عبر واتساب
    </button>
    <button style="width:100%; background:none; border:none; color:var(--danger); margin-top:12px;" onclick="closeModal('cartModal')">إغلاق</button>
  </div>
</div>

<!-- Image Modal -->
<div id="imageModal" class="modal" onclick="closeModal('imageModal')">
  <img id="modalImg" style="max-width:95%; max-height:80%; border-radius:20px;">
</div>

<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.1/firebase-app.js";
  import { getDatabase, ref, onValue, get, push, set } from "https://www.gstatic.com/firebasejs/10.8.1/firebase-database.js";

  const firebaseConfig = {
    apiKey: "AIzaSyAe1ZmzSkemgaCoqRtKc0Yjn85F36obpsA",
    authDomain: "chcleanstore-596af.firebaseapp.com",
    databaseURL: "https://chcleanstore-596af-default-rtdb.europe-west1.firebasedatabase.app",
    projectId: "chcleanstore-596af",
    storageBucket: "chcleanstore-596af.firebasestorage.app",
    messagingSenderId: "198046127297",
    appId: "1:198046127297:web:d54d64a66e1ae315337040",
    measurementId: "G-XKN3FQ46XY"
  };

  const app = initializeApp(firebaseConfig);
  const db = getDatabase(app);

  const IMGBB_KEY = "d9c4169515827e24b5c280cd7789cefb";
  const WHATSAPP_NUMBER = "213540667186";
  const STORE_NAME = "CH Clean Store";

  const stopWords = new Set(['DE', 'DU', 'DES', 'LE', 'LA', 'LES', 'ET', 'POUR', 'AVEC', 'À', 'AUX', 'SUR', 'DANS', 'PAR', 'UN', 'UNE', 'EN']);

  function extractKeyword(productName) {
    const words = productName.toUpperCase().split(/\s+/);
    for (let word of words) {
      if (!stopWords.has(word) && word.length >= 3 && /^[A-Z0-9]+$/.test(word)) {
        return word;
      }
    }
    return null;
  }

  function buildFamiliesFromProducts(products, minCount = 5) {
    const freq = new Map();
    products.forEach(p => {
      const kw = extractKeyword(p.name);
      if (kw) freq.set(kw, (freq.get(kw) || 0) + 1);
    });
    const families = [];
    for (let [fam, count] of freq.entries()) {
      if (count >= minCount) families.push(fam);
    }
    families.sort();
    return families;
  }

  let state = {
    isVIP: false,
    allProducts: [],
    cart: JSON.parse(localStorage.getItem('cart_new')) || [],
    currentPage: 1,
    itemsPerPage: 20,
    activeFamily: 'الكل',
    search: '',
    lastOrder: null
  };

  onValue(ref(db, 'store/cover'), (snap) => {
    const img = document.getElementById('coverImage');
    if (snap.exists() && snap.val().url) img.src = snap.val().url;
  });

  onValue(ref(db, 'products'), (snapshot) => {
    const data = snapshot.val() || {};
    state.allProducts = Object.entries(data)
      .map(([id, p]) => ({ id, ...p }))
      .filter(p => !p.hidden);
    renderCategories();
    renderUI();
  });

  window.renderCategories = () => {
    const bar = document.getElementById('categoriesBar');
    const families = buildFamiliesFromProducts(state.allProducts, 5);
    const buttons = ['الكل', ...families];
    bar.innerHTML = buttons.map(f => `
      <button class="cat-btn ${state.activeFamily === f ? 'active' : ''}" onclick="setFamily('${f}')">${f}</button>
    `).join('');
  };

  window.setFamily = (family) => {
    state.activeFamily = family;
    state.currentPage = 1;
    renderCategories();
    renderUI();
  };

  window.renderUI = () => {
    const container = document.getElementById('productsContainer');
    container.innerHTML = '';

    let filtered = state.allProducts.filter(p => {
      if (state.activeFamily !== 'الكل') {
        const familyOfProduct = extractKeyword(p.name);
        if (familyOfProduct !== state.activeFamily) return false;
      }
      const matchSearch = p.name.toLowerCase().includes(state.search.toLowerCase());
      return matchSearch;
    });

    const start = (state.currentPage - 1) * state.itemsPerPage;
    const paginated = filtered.slice(start, start + state.itemsPerPage);

    paginated.forEach(p => {
      const inCart = state.cart.find(i => i.id === p.id);
      const qty = inCart ? inCart.quantity : 0;
      const price = state.isVIP ? (p.price3 || p.price2 || p.price) : (p.price2 || p.price);
      const formattedPrice = Number(price || 0).toLocaleString();

      const card = document.createElement('div');
      card.className = 'product-card';
      card.innerHTML = `
        <img src="${p.imageUrl || p.img || 'https://via.placeholder.com/150'}" onclick="viewImage('${p.imageUrl || p.img}')" loading="lazy">
        <div class="product-info">
          <h3>${escapeHtml(p.name)}</h3>
          <div class="product-price">${formattedPrice} دج</div>
          <div class="qty-controls">
            <button class="qty-btn" onclick="updateQty('${p.id}', -1)">-</button>
            <input type="number" class="qty-input" value="${qty}" min="0" onchange="manualQty('${p.id}', this.value)">
            <button class="qty-btn" onclick="updateQty('${p.id}', 1)">+</button>
          </div>
        </div>
      `;
      container.appendChild(card);
    });

    updateCartBadge();
    renderPagination(filtered.length, state.currentPage);
  };

  function renderPagination(totalItems, page) {
    const pagination = document.getElementById("pagination");
    pagination.innerHTML = "";
    const totalPages = Math.ceil(totalItems / state.itemsPerPage);
    if (totalPages <= 1) return;

    const createBtn = (text, targetPage, active = false, disabled = false) => {
      const btn = document.createElement("button");
      btn.textContent = text;
      btn.style.cssText = `
        min-width: 38px;
        height: 38px;
        border: none;
        border-radius: 10px;
        margin: 4px;
        background: ${active ? "#10b981" : "#ffffff"};
        color: ${active ? "#ffffff" : "#333"};
        font-weight: 600;
        box-shadow: 0 2px 6px rgba(0,0,0,0.08);
        cursor: ${disabled ? "default" : "pointer"};
        opacity: ${disabled ? "0.5" : "1"};
      `;
      if (!disabled) btn.onclick = () => goToPage(targetPage);
      pagination.appendChild(btn);
    };

    createBtn("‹", page - 1, false, page === 1);
    createBtn("1", 1, page === 1);
    if (page > 3) {
      const dots = document.createElement("span");
      dots.textContent = "...";
      dots.style.margin = "0 5px";
      pagination.appendChild(dots);
    }
    for (let i = Math.max(2, page - 3); i <= Math.min(totalPages - 1, page + 3); i++) {
      createBtn(i, i, page === i);
    }
    if (page < totalPages - 2) {
      const dots = document.createElement("span");
      dots.textContent = "...";
      dots.style.margin = "0 5px";
      pagination.appendChild(dots);
    }
    if (totalPages > 1) createBtn(totalPages, totalPages, page === totalPages);
    createBtn("›", page + 1, false, page === totalPages);
  }

  window.goToPage = (p) => { state.currentPage = p; renderUI(); window.scrollTo(0, 0); };

  window.updateQty = (id, change) => {
    const p = state.allProducts.find(x => x.id === id);
    const idx = state.cart.findIndex(x => x.id === id);
    const price = state.isVIP ? (p.price3 || p.price2 || p.price) : (p.price2 || p.price);
    if (idx > -1) {
      state.cart[idx].quantity += change;
      if (state.cart[idx].quantity <= 0) state.cart.splice(idx, 1);
    } else if (change > 0) {
      state.cart.push({ id: p.id, name: p.name, price: Number(price), serial: p.serial || "---", quantity: 1 });
    }
    localStorage.setItem('cart_new', JSON.stringify(state.cart));
    renderUI();
  };

  window.manualQty = (id, val) => {
    const p = state.allProducts.find(x => x.id === id);
    const quantity = parseInt(val) || 0;
    const price = state.isVIP ? (p.price3 || p.price2 || p.price) : (p.price2 || p.price);
    const idx = state.cart.findIndex(x => x.id === id);
    if (quantity > 0) {
      if (idx > -1) state.cart[idx].quantity = quantity;
      else state.cart.push({ id: p.id, name: p.name, price: Number(price), serial: p.serial || "---", quantity });
    } else {
      if (idx > -1) state.cart.splice(idx, 1);
    }
    localStorage.setItem('cart_new', JSON.stringify(state.cart));
    renderUI();
  };

  window.updateCartBadge = () => {
    const badge = document.getElementById('cartBadge');
    const count = state.cart.reduce((a, b) => a + b.quantity, 0);
    badge.innerText = count;
    badge.style.display = count > 0 ? 'inline-block' : 'none';
  };

  window.openCart = () => {
    const list = document.getElementById('cartItemsList');
    list.innerHTML = '';
    let total = 0;
    state.cart.forEach(item => {
      total += item.price * item.quantity;
      list.innerHTML += `<div style="display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid #eee;"><span>${item.name} (x${item.quantity})</span><span>${(item.price * item.quantity).toLocaleString()} دج</span></div>`;
    });
    list.innerHTML += `<button onclick="clearCart()" style="width:100%; margin-top:12px; background:#e74c3c; color:white; border:none; padding:10px; border-radius:40px;">🗑️ مسح السلة</button>`;
    document.getElementById('cartTotal').innerText = `المجموع: ${total.toLocaleString()} دج`;
    document.getElementById('cartModal').style.display = 'flex';
  };

  window.clearCart = () => { state.cart = []; localStorage.removeItem('cart_new'); renderUI(); closeModal('cartModal'); };

  // ============================================================
  // زر تحديد الموقع (يحافظ على النص الأصلي)
  // ============================================================
  document.getElementById("locationBtn")?.addEventListener("click", () => {
    if (!navigator.geolocation) {
      alert("❌ متصفحك لا يدعم خاصية تحديد الموقع");
      return;
    }
    
    const btn = document.getElementById("locationBtn");
    const originalText = btn.innerHTML;
    const addressInput = document.getElementById("custAddress");
    const existingAddress = addressInput.value.trim();
    
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري التحميل...';
    
    navigator.geolocation.getCurrentPosition(
      (position) => {
        const lat = position.coords.latitude;
        const lng = position.coords.longitude;
        const mapsUrl = `https://maps.google.com/?q=${lat},${lng}`;
        
        // إضافة الرابط إلى النص الموجود بدلاً من استبداله
        if (existingAddress) {
          // إذا كان الرابط موجوداً بالفعل، لا نضيفه مرة أخرى
          if (existingAddress.includes("maps.google.com")) {
            alert("📍 رابط الموقع موجود مسبقاً");
          } else {
            addressInput.value = `${existingAddress} | ${mapsUrl}`;
            alert("✅ تم إضافة رابط الموقع بجانب العنوان");
          }
        } else {
          addressInput.value = mapsUrl;
          alert("✅ تم تحديد موقعك بنجاح");
        }
        
        btn.disabled = false;
        btn.innerHTML = originalText;
      },
      (error) => {
        btn.disabled = false;
        btn.innerHTML = originalText;
        
        let errorMsg = "❌ حدث خطأ";
        switch(error.code) {
          case error.PERMISSION_DENIED:
            errorMsg = "❌ الرجاء السماح بتحديد الموقع";
            break;
          case error.POSITION_UNAVAILABLE:
            errorMsg = "❌ معلومات الموقع غير متوفرة";
            break;
          case error.TIMEOUT:
            errorMsg = "❌ انتهى وقت المحاولة";
            break;
        }
        alert(errorMsg);
      },
      {
        enableHighAccuracy: true,
        timeout: 10000,
        maximumAge: 0
      }
    );
  });

  function generateWhatsAppMessage(name, phone, address, items, total) {
  // بناء قائمة المنتجات بشكل مبسط
  let itemsText = "";
  items.forEach((item) => {
    itemsText += `${item.quantity} ${item.name} x ${item.price.toLocaleString()} DA = ${(item.price * item.quantity).toLocaleString()} DA\n`;
  });
  
  // معالجة العنوان أو رابط الموقع
  let locationText = "";
  if (address.includes("maps.google.com")) {
    locationText = `الموقع: ${address}\n`;
  } else if (address && address.trim() !== "") {
    locationText = `العنوان: ${address}\n`;
  }
  
  // الرسالة النهائية بشكل احترافي
  return `🛍️ طلب جديد من ${STORE_NAME}\n\n` +
    `العميل: ${name}\n` +
    `الهاتف: ${phone}\n` +
    locationText +
    `\n${itemsText}\n` +
    `الإجمالي: ${total.toLocaleString()} DA\n\n` +
    `📅 ${new Date().toLocaleString('ar-DZ')}`;
}

  async function saveOrderToFirebase(orderData) {
    try {
      const ordersRef = ref(db, 'whatsappOrders');
      const newOrderRef = push(ordersRef);
      orderData.timestamp = Date.now();
      orderData.status = "pending";
      await set(newOrderRef, orderData);
      console.log("✅ تم حفظ الطلب في Firebase:", orderData);
      return true;
    } catch(e) {
      console.error("خطأ في حفظ الطلب في Firebase:", e);
      return false;
    }
  }

  window.submitOrder = async () => {
    const name = document.getElementById('custName').value.trim();
    const phone = document.getElementById('custPhone').value.trim();
    const address = document.getElementById('custAddress').value.trim();
    
    if (!name || !phone || !address || state.cart.length === 0) {
      alert("يرجى ملء جميع البيانات وإضافة منتجات للسلة");
      return;
    }
    
    const total = state.cart.reduce((a, b) => a + (b.price * b.quantity), 0);
    const message = generateWhatsAppMessage(name, phone, address, state.cart, total);
    const encodedMessage = encodeURIComponent(message);
    
    const orderToSave = {
      customerName: name,
      phone: phone,
      address: address,
      items: [...state.cart],
      totalPrice: total
    };
    
    const saved = await saveOrderToFirebase(orderToSave);
    
    if (saved) {
      window.open(`https://wa.me/${WHATSAPP_NUMBER}?text=${encodedMessage}`, '_blank');
      
      state.cart = [];
      localStorage.removeItem('cart_new');
      renderUI();
      
      document.getElementById('custName').value = '';
      document.getElementById('custPhone').value = '';
      document.getElementById('custAddress').value = '';
      
      alert("✅ تم إرسال الطلب إلى واتساب وحفظه في النظام");
    } else {
      alert("❌ حدث خطأ في حفظ الطلب، يرجى المحاولة مرة أخرى");
    }
  };

  window.checkVIP = async () => {
    const code = document.getElementById('vipInput').value.trim();
    if (!code) return;
    const snap = await get(ref(db, 'store/clientCode'));
    if (!snap.exists()) { alert("الكود غير موجود"); return; }
    if (code === snap.val().code) {
      state.isVIP = true;
      state.cart = [];
      localStorage.removeItem('cart_new');
      document.getElementById('vipStatus').innerHTML = "✅ تم تفعيل أسعار الجملة";
      document.body.classList.add('vip-active');
      renderUI();
      alert("تم التفعيل بنجاح! الآن يمكنك الشراء بأسعار الجملة.");
    } else { alert("الكود غير صحيح"); }
  };

  window.toggleSearch = () => document.getElementById('searchContainer').classList.toggle('active');
  window.toggleVIPBox = () => {
    const box = document.getElementById('vipBox');
    box.style.display = box.style.display === 'none' ? 'block' : 'none';
  };
  window.viewImage = (url) => { document.getElementById('modalImg').src = url; document.getElementById('imageModal').style.display = 'flex'; };
  window.closeModal = (id) => document.getElementById(id).style.display = 'none';

  document.getElementById('searchInput').addEventListener('input', (e) => {
    state.search = e.target.value;
    state.currentPage = 1;
    renderUI();
  });

  function escapeHtml(str) {
    if (!str) return '';
    return String(str).replace(/[&<>]/g, function(m) {
      if (m === '&') return '&amp;';
      if (m === '<') return '&lt;';
      if (m === '>') return '&gt;';
      return m;
    });
  }
</script>

